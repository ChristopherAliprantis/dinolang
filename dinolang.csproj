<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
	<AssemblyTitle>Dino</AssemblyTitle>
	<AssemblyName>Dino</AssemblyName>
    <PublishAot>true</PublishAot>
    <InvariantGlobalization>true</InvariantGlobalization>
    <Title>Dino</Title>
    <Product>$(AssemblyName)</Product>
	  <Copyright>No One</Copyright>
	  <ApplicationIcon>Assets\DinoLogo.ico</ApplicationIcon>
    <Description>Dino programming language</Description>
    <RepositoryUrl>https://github.com/ChristopherAliprantis/dinolang</RepositoryUrl>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="CommandLineParser" Version="2.9.1" />
  </ItemGroup>

</Project>
