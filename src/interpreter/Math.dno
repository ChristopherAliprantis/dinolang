#func ispos(n); #if (<(0, n)); return(true); #endif; return(false); #endfunc;
#func isneg(n); #if (>(0, n)); return(true); #endif; return(false); #endfunc;
#func isneut(n); #if (==(n, 0)); return(true); #endif; return(false); #endfunc;

#func abs(n);
    #if (>(n, -1));
        return(n);
    #endif;
    return(*(n, -1));
#endfunc;

#func neg(n);
    return(*(n, -1));
#endfunc;